# Supabase project credentials
# Find these in your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret — must match the "JWT Secret" shown in Supabase → Settings → API
JWT_SECRET=your-jwt-secret

# Mailgun credentials for email notifications
# Sign up at mailgun.com → Sending → Domains → your domain
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_SENDER_EMAIL=CarePets <noreply@mg.yourdomain.com>
